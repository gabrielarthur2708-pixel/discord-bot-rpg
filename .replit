modules = ["nodejs-20"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Discord Bot"

[[workflows.workflow]]
name = "Discord Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd discord-bot && node index.js"
waitForPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd discord-bot && node index.js"]

[[ports]]
localPort = 3000
externalPort = 3000
